# Backend Configuration

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Storage path for JSON data files
STORAGE_PATH=../data

# CORS configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Log level
LOG_LEVEL=info

# Log configuration
LOG_DIR=./logs
LOG_FILE_MAX_SIZE=10m
LOG_FILE_KEEP=5

# Executor npm cache path (optional)
# Set this to override npm cache directory for executor subprocesses.
# Useful on Windows when the default npm cache path has permission issues (EPERM).
# Example: EXECUTOR_NPM_CACHE=C:\Users\<username>\.npm-cache
# EXECUTOR_NPM_CACHE=
